# Local Development Environment
# Copy this file to .env and fill in local development values

# API Server
NODE_ENV=development
PORT=3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=powermech_ai_dev
DB_USER=powermech_dev
DB_PASSWORD=dev_local_only

# Migrations
MIGRATIONS_DIR=./migrations

# Log level
LOG_LEVEL=debug
