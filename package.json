{
  "name": "powermech-ai",
  "version": "0.1.0",
  "description": "AI Operating System / SaaS platform for service centers.",
  "private": true,
  "license": "PROPRIETARY",
  "type": "commonjs",
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "dev": "ts-node-dev --respawn --transpile-only apps/api/src/main.ts",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage --passWithNoTests",
    "lint": "eslint \"apps/api/src/**/*.ts\"",
    "lint:fix": "eslint \"apps/api/src/**/*.ts\" --fix",
    "db:migrate": "node-pg-migrate up -m ./migrations -d postgres://powermech_dev:dev_local_only@localhost:5432/powermech_ai_dev",
    "db:migrate:down": "node-pg-migrate down -m ./migrations -d postgres://powermech_dev:dev_local_only@localhost:5432/powermech_ai_dev",
    "db:reset": "node-pg-migrate down -t 0 -m ./migrations -d postgres://powermech_dev:dev_local_only@localhost:5432/powermech_ai_dev && node-pg-migrate up -m ./migrations -d postgres://powermech_dev:dev_local_only@localhost:5432/powermech_ai_dev",
    "db:seed:workspace": "node scripts/seed-demo.js",
    "db:seed:demo": "node scripts/seed-demo-repair-case.js",
    "repository:validate": "node scripts/validate-repository.js"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-fastify": "^10.4.15",
    "fastify": "^4.29.0",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": "apps/api/src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {"^.+\\.(t|j)s$": "ts-jest"},
    "testEnvironment": "node"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "node-pg-migrate": "^7.9.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.2"
  }
}
